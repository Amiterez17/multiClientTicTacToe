<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="480.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="il.cshaifasweng.OCSFMediatorExample.client.SecondaryController">
    <children>
        <Label fx:id="titleLabel" alignment="CENTER" prefHeight="30.0" prefWidth="400.0" text="Connect to Server">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" top="10.0" />
            </VBox.margin>
        </Label>

        <Label alignment="CENTER" text="Please enter the server details to start playing" textFill="#666666">
            <font>
                <Font size="13.0" />
            </font>
        </Label>

        <VBox maxWidth="280.0" spacing="10.0">
            <children>
                <Label text="Host Address:" textFill="#444444">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <TextField fx:id="hostField" prefHeight="35.0" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" text="localhost" />

                <Label text="Port:" textFill="#444444">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="portField" prefHeight="35.0" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" text="3000" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </VBox>

        <Label fx:id="errorLabel" alignment="CENTER" prefHeight="20.0" prefWidth="350.0" textFill="#d9534f">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
            <VBox.margin>
                <Insets top="5.0" />
            </VBox.margin>
        </Label>

        <Button fx:id="connectBtn" mnemonicParsing="false" onAction="#connectToServer" prefHeight="38.0" prefWidth="180.0" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-color: #5cb85c; -fx-border-color: #4cae4c; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="Connect" />
    </children>
</VBox>